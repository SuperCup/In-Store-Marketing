# AI_PROVIDER can be auto, deepseek, kimi, openai-compatible, or none.
# auto tries DeepSeek first, then Kimi when both keys are configured.
AI_PROVIDER=auto

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Kimi / Moonshot
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k

# Generic OpenAI-compatible provider
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=

# Generation controls
ARTICLES_PER_DAY=3
AI_REQUIRED=false
FORCE_REGENERATE=false

# WeCom daily notification
QYWX_WEBHOOK_URL=
QYWX_NOTIFY_REQUIRED=false
QYWX_NOTIFY_DRY_RUN=false

# Optional: override config/site.json siteUrl in notifications
SITE_PUBLIC_URL=
